{
  "name": "flagAI",
  "version": "0.1.0",
  "description": "Flag YouTube channels that publish AI-generated music",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": [
    "chrome-extension",
    "youtube",
    "ai-music",
    "open-source"
  ],
  "author": "Steven",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.1.2"
}
